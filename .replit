modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
# Blok 0 — OWNER_PIN must never be committed here (it was previously
# hardcoded in plaintext). Set it as a real Replit Secret instead:
# Tools -> Secrets -> OWNER_PIN. See docs/BLOK0_SECRET_ROTATION.md.
